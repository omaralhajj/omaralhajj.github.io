---
import { getCollection } from 'astro:content'

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5)

function formatDate(date: Date) {
  return date.toLocaleDateString('en-GB', { year: 'numeric', month: 'short', day: 'numeric' })
}
---

<aside class="hidden xl:flex xl:flex-col xl:w-56 xl:shrink-0 xl:sticky xl:top-20 xl:pt-20 xl:pb-12 fade-in">
  <div class="flex items-baseline justify-between mb-4">
    <h2 class="font-mono text-sm" style="color: var(--color-accent);" data-i18n="blog_heading">Recent Posts</h2>
    <a
      href="/blog"
      class="text-xs transition-colors"
      style="color: var(--color-text-muted);"
      onmouseover="this.style.color='var(--color-accent)'"
      onmouseout="this.style.color='var(--color-text-muted)'"
      data-i18n="blog_view_all"
    >
      View all →
    </a>
  </div>

  {posts.length === 0 ? (
    <p class="text-xs" style="color: var(--color-text-muted);" data-i18n="blog_empty">No posts yet.</p>
  ) : (
    <ul class="flex flex-col gap-2" style="list-style: none; padding: 0; margin: 0;">
      {posts.map(post => (
        <li>
          <a
            href={`/blog/${post.id}`}
            class="sidebar-post-card block p-3 rounded-lg border"
            style="border-color: var(--color-border); background-color: var(--color-card);"
          >
            <span class="text-xs font-medium block mb-1 leading-snug" style="color: var(--color-text);">{post.data.title}</span>
            <span class="text-xs" style="color: var(--color-text-muted);">{formatDate(post.data.pubDate)}</span>
          </a>
        </li>
      ))}
    </ul>
  )}
</aside>

<style>
  .sidebar-post-card {
    transition: border-color 0.2s, transform 0.2s;
  }
  .sidebar-post-card:hover {
    border-color: var(--color-accent);
    transform: translateX(2px);
  }
</style>
