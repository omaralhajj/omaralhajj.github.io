---
const links = [
  { label: 'LinkedIn', href: 'https://linkedin.com/in/omar-alhajj', display: 'linkedin.com/in/omar-alhajj' },
]
---

<section id="contact" class="col py-12 sm:py-16 border-t fade-in" style="border-color: var(--color-border);">
  <h2 class="font-mono text-sm mb-6" style="color: var(--color-accent);">Contact</h2>
  <p class="text-base leading-relaxed mb-8" style="color: var(--color-text-muted);">
    Open to relevant software engineering conversations, platform-focused roles, and collaboration opportunities.
  </p>
  <div class="space-y-3">
    {links.map(link => (
      <div class="flex flex-col items-start gap-1 sm:flex-row sm:items-center sm:gap-4">
        <span class="font-mono text-xs sm:w-16" style="color: var(--color-text-muted);">{link.label}</span>
        <a
          href={link.href}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm break-all transition-colors hover:text-[var(--color-accent)]"
          style="color: var(--color-text);"
        >
          {link.display}
        </a>
      </div>
    ))}
  </div>
</section>
