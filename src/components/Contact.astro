---
const links = [
  { label: 'LinkedIn', href: 'https://linkedin.com/in/omar-alhajj', display: 'linkedin.com/in/omar-alhajj' },
]
---

<section id="contact" class="col py-12 sm:py-16 border-t fade-in" style="border-color: var(--color-border);">
  <h2 class="font-mono text-sm mb-6" style="color: var(--color-accent);" data-i18n="contact_heading">Contact</h2>
  <p class="text-base leading-relaxed mb-8" style="color: var(--color-text-muted);" data-i18n="contact_blurb">
    Open to relevant software engineering conversations, platform-focused roles, and collaboration opportunities.
  </p>
  <div class="space-y-3">
    {links.map(link => (
      <div class="flex flex-col items-start gap-1 sm:flex-row sm:items-center sm:gap-4">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-linkedin" viewBox="0 0 16 16">
          <path d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854zm4.943 12.248V6.169H2.542v7.225zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248S2.4 3.226 2.4 3.934c0 .694.521 1.248 1.327 1.248zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016l.016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225z"/>
        </svg>
        <div class="flex items-center gap-2">
          <a
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm break-all transition-colors hover:text-[var(--color-accent)]"
            style="color: var(--color-text);"
          >
            {link.display}
          </a>
          <button
            class="copy-btn header-icon-btn shrink-0"
            data-copy={link.href}
            aria-label={`Copy ${link.label} link`}
          >
            <!-- Copy icon -->
            <svg class="copy-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>
            </svg>
            <!-- Check icon (shown after copy) -->
            <svg class="check-icon hidden" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </button>
        </div>
      </div>
    ))}
  </div>
</section>

<script>
  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach(btn => {
    const copyIcon = btn.querySelector('.copy-icon')!
    const checkIcon = btn.querySelector('.check-icon')!
    let timeout: ReturnType<typeof setTimeout>

    btn.addEventListener('click', async () => {
      const text = btn.dataset.copy!
      await navigator.clipboard.writeText(text)

      copyIcon.classList.add('hidden')
      checkIcon.classList.remove('hidden')
      btn.style.color = 'var(--color-accent)'

      clearTimeout(timeout)
      timeout = setTimeout(() => {
        copyIcon.classList.remove('hidden')
        checkIcon.classList.add('hidden')
        btn.style.color = ''
      }, 2000)
    })
  })
</script>
